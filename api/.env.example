# Hotel Reservation Multi-Agent System - Environment Variables
# Copy this file to .env and fill in your actual values

# ===========================================
# API KEYS (Required for external services)
# ===========================================

# OpenWeatherMap API Key (required for weather service)
# Get your free API key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ===========================================
# SERVICE URLs (Optional - defaults provided)
# ===========================================

# Hotel Data API base URL (default: http://localhost:8080/api/data/hotels)
# HOTEL_API_BASE=http://localhost:8080/api/data/hotels

# Weather API base URL (default: https://api.openweathermap.org/data/2.5/weather)
# WEATHER_API_BASE=https://api.openweathermap.org/data/2.5/weather

# ===========================================
# SERVER CONFIGURATION (Optional)
# ===========================================

# Server port (default: 8080)
# SERVER_PORT=8080

# Logging level: TRACE, DEBUG, INFO, WARN, ERROR (default: DEBUG)
# LOG_LEVEL=DEBUG

# ===========================================
# CNP PROTOCOL (Optional - defaults provided)
# ===========================================

# Proposal collection deadline in milliseconds (default: 30000)
# CNP_PROPOSAL_DEADLINE_MS=30000

# Maximum shortlisted candidates for sequential negotiation (default: 3)
# CNP_MAX_CANDIDATES=3

# Maximum negotiation rounds before forcing a decision (default: 5)
# CNP_MAX_NEGOTIATION_ROUNDS=5

# ===========================================
# PLAYGROUND TIMING (Optional - defaults provided)
# ===========================================

# Internal data-fetch API port (default: 7070)
# API_PORT=7070

# Playground timeout tick count (default: 100000)
# PLAYGROUND_TIMEOUT_TICK=100000

# Playground step delay in milliseconds (default: 1500)
# PLAYGROUND_STEP_DELAY=1500
