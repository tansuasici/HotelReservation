<project xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://maven.apache.org/POM/4.0.0"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>ai.scop</groupId>
    <artifactId>scop-ui</artifactId>
    <version>2026.02.03</version>

    <name>${project.groupId}.${project.artifactId}</name>
    <description>SCOP Framework - UI</description>
    <url>https://gitlab.com/scop-framework/scop-ui</url>
    <licenses>
        <license>
            <name>Proprietary License</name>
            <distribution>manual</distribution>
            <comments>This software is licensed under a proprietary license. Unauthorized copying, modification, or
                distribution is prohibited.
            </comments>
        </license>
    </licenses>
    <developers>
        <developer>
            <name>Önder Gürcan</name>
            <email>onder.gurcan@gmail.com</email>
        </developer>
    </developers>

    <properties>
        <!-- Configurator -->
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <jdk.version>21</jdk.version>

        <scop-core.version>2026.02.03</scop-core.version>

        <!-- Versions -->
        <httpclient5.version>5.6</httpclient5.version>

        <!-- Maven compiler version -->
        <maven.compiler.release>21</maven.compiler.release>

        <!-- Maven plugins -->
        <maven-compiler-plugin.version>3.14.1</maven-compiler-plugin.version>

        <jackson-databind.version>2.21.0</jackson-databind.version>
        <flexmark.version>0.64.8</flexmark.version>
        <json.version>20251224</json.version>
        <jxmapviewer2.version>2.8.1</jxmapviewer2.version>
        <jgraphx.version>4.2.2</jgraphx.version>
        <jgrapht-ext.version>1.5.2</jgrapht-ext.version>
        <aws-lambda-java-core.version>1.4.0</aws-lambda-java-core.version>
        <aws-lambda-java-events.version>3.16.1</aws-lambda-java-events.version>
        <spring-boot-starter-web.version>4.0.2</spring-boot-starter-web.version>
    </properties>

    <!-- Tell maven where snapshots and releases should be deployed. -->
    <repositories>
        <repository>
            <id>gitlab-maven</id>
            <url>${CI_API_V4_URL}/projects/${CI_PROJECT_ID}/packages/maven</url>
        </repository>
        <repository>
            <id>scop-core</id>
            <url>https://gitlab.com/api/v4/projects/62548306/packages/maven</url>
            <releases>
                <enabled>true</enabled>
            </releases>
            <snapshots>
                <enabled>true</enabled>
            </snapshots>
        </repository>
    </repositories>
    <distributionManagement>
        <repository>
            <id>gitlab-maven</id>
            <url>${CI_API_V4_URL}/projects/${CI_PROJECT_ID}/packages/maven</url>
        </repository>
        <snapshotRepository>
            <id>gitlab-maven</id>
            <url>${CI_API_V4_URL}/projects/${CI_PROJECT_ID}/packages/maven</url>
        </snapshotRepository>
    </distributionManagement>

    <!-- Define the Maven dependencies.-->
    <dependencies>
        <dependency>
            <groupId>ai.scop</groupId>
            <artifactId>scop-core</artifactId>
            <version>${scop-core.version}</version>
        </dependency>
        <dependency>
            <groupId>org.apache.httpcomponents.client5</groupId>
            <artifactId>httpclient5</artifactId>
            <version>${httpclient5.version}</version>
        </dependency>
        <dependency>
            <groupId>org.jxmapviewer</groupId>
            <artifactId>jxmapviewer2</artifactId>
            <version>${jxmapviewer2.version}</version>
        </dependency>
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
            <version>${jackson-databind.version}</version>
        </dependency>
        <!-- https://mvnrepository.com/artifact/com.vladsch.flexmark/flexmark -->
        <dependency>
            <groupId>com.vladsch.flexmark</groupId>
            <artifactId>flexmark</artifactId>
            <version>${flexmark.version}</version>
        </dependency>
        <dependency>
            <groupId>org.json</groupId>
            <artifactId>json</artifactId>
            <version>${json.version}</version>
        </dependency>
        <dependency>
            <groupId>com.github.vlsi.mxgraph</groupId>
            <artifactId>jgraphx</artifactId>
            <version>${jgraphx.version}</version>
        </dependency>
        <!-- https://mvnrepository.com/artifact/org.jgrapht/jgrapht-ext -->
        <dependency>
            <groupId>org.jgrapht</groupId>
            <artifactId>jgrapht-ext</artifactId>
            <version>${jgrapht-ext.version}</version>
        </dependency>
        <!-- AWS Lambda Environment -->
        <dependency>
            <groupId>com.amazonaws</groupId>
            <artifactId>aws-lambda-java-core</artifactId>
            <version>${aws-lambda-java-core.version}</version>
        </dependency>
        <dependency>
            <groupId>com.amazonaws</groupId>
            <artifactId>aws-lambda-java-events</artifactId>
            <version>${aws-lambda-java-events.version}</version>
        </dependency>
        <!--  the Spring Web dependency -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
            <version>${spring-boot-starter-web.version}</version>
        </dependency>

    </dependencies>

    <build>
        <resources>
            <resource>
                <directory>src/main/resources</directory>
            </resource>
        </resources>

        <plugins>
            <!-- Add the Maven Compiler Plugin -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>${maven-compiler-plugin.version}</version>
                <configuration>
                    <compilerArgs>
                        <arg>-parameters</arg>
                    </compilerArgs>
                    <source>21</source>
                    <target>21</target>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>