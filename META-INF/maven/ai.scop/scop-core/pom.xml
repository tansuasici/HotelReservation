<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>

	<groupId>ai.scop</groupId>
	<artifactId>scop-core</artifactId>
    <version>2026.02.03</version>

	<name>${project.groupId}.${project.artifactId}</name>
	<description>SCOP Framework - CORE</description>
	<url>https://gitlab.com/scop-framework/ai.scop.core</url>
	<licenses>
		<license>
            <name>Proprietary License</name>
            <distribution>manual</distribution>
            <comments>This software is licensed under a proprietary license. Unauthorized copying, modification, or distribution is prohibited.</comments>
        </license>
	</licenses>
	<developers>
		<developer>
			<name>Önder Gürcan</name>
			<email>onder.gurcan@gmail.com</email>
		</developer>
	</developers>

	<properties>
		<!-- Sets the character encoding for compiling the source code. UTF-8 is a widely used encoding that supports all Unicode characters. -->
		<project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

		<!-- Specifies the version of the Java Development Kit (JDK) to use for compiling the project. JDK 21 is targeted here. -->
		<jdk.version>21</jdk.version>

		<!-- Maven compiler plugin configuration to specify the source and target Java version. This ensures compatibility with Java 21 features. -->
		<maven.compiler.release>21</maven.compiler.release>

		<!-- Specifies the version of the JaCoCo Maven Plugin, which is a code coverage library for Java, used for measuring how many lines of code are tested. -->
		<jacoco-maven-plugin.version>0.8.14</jacoco-maven-plugin.version>

		<!-- These properties define the versions of various dependencies used in the project, making it easy to update a version in one place. -->
		<logback.version>1.5.26</logback.version>
		<slf4j.version>2.1.0-alpha1</slf4j.version>
		<org.eclipse.paho.version>1.2.5</org.eclipse.paho.version>
		<commons-lang3.version>3.20.0</commons-lang3.version>
		<json.version>20251224</json.version>
		<junit-jupiter.version>6.0.2</junit-jupiter.version>
		<jgrapht-core.version>1.5.2</jgrapht-core.version>
		<jackson-databind.version>2.21.0</jackson-databind.version>
	</properties>

	<!-- Define the repositories from which Maven can download dependencies. -->
	<repositories>
		<!-- Specify the GitLab Maven repository for retrieving project dependencies. -->
		<repository>
			<id>gitlab-maven</id>
			<url>${CI_API_V4_URL}/projects/${CI_PROJECT_ID}/packages/maven</url>
		</repository>
	</repositories>

	<!-- Configure the distribution management to specify where artifacts, such as releases and snapshots, should be deployed. -->
	<distributionManagement>
		<!-- Define the repository for deploying release versions of the project. -->
		<repository>
			<id>gitlab-maven</id>
			<url>${CI_API_V4_URL}/projects/${CI_PROJECT_ID}/packages/maven</url>
		</repository>
		<!-- Define the repository for deploying snapshot versions of the project. -->
		<snapshotRepository>
			<id>gitlab-maven</id>
			<url>${CI_API_V4_URL}/projects/${CI_PROJECT_ID}/packages/maven</url>
		</snapshotRepository>
	</distributionManagement>


	<!-- Define the Maven dependencies.-->
	<dependencies>
		<!-- org.json: Provides JSON processing capabilities to parse, transform, and query JSON data structures -->
		<dependency>
			<groupId>org.json</groupId>
			<artifactId>json</artifactId>
			<version>${json.version}</version>
		</dependency>

		<!-- JUnit Jupiter API: The new programming and extension model for writing tests in JUnit 5 -->
		<dependency>
			<groupId>org.junit.jupiter</groupId>
			<artifactId>junit-jupiter-api</artifactId>
			<version>${junit-jupiter.version}</version>
			<scope>compile</scope>
		</dependency>

		<!-- JUnit Jupiter Params: Provides support for parameterized tests in JUnit 5 -->
		<dependency>
			<groupId>org.junit.jupiter</groupId>
			<artifactId>junit-jupiter-params</artifactId>
			<version>${junit-jupiter.version}</version>
			<scope>test</scope>
		</dependency>

		<!-- JGraphT: A free Java graph library that provides mathematical graph-theory objects and algorithms -->
		<dependency>
			<groupId>org.jgrapht</groupId>
			<artifactId>jgrapht-core</artifactId>
			<version>${jgrapht-core.version}</version>
		</dependency>

		<!-- org.eclipse.paho.client.mqttv3: Provides an MQTT client for communicating with MQTT servers -->
		<dependency>
			<groupId>org.eclipse.paho</groupId>
			<artifactId>org.eclipse.paho.client.mqttv3</artifactId>
			<version>${org.eclipse.paho.version}</version>
		</dependency>

		<!-- Apache Commons Lang3: Provides extra functionality for classes in java.lang -->
		<dependency>
			<groupId>org.apache.commons</groupId>
			<artifactId>commons-lang3</artifactId>
			<version>${commons-lang3.version}</version>
		</dependency>

		<!-- Logback Classic: Provides a robust logging framework -->
		<dependency>
			<groupId>ch.qos.logback</groupId>
			<artifactId>logback-classic</artifactId>
			<version>${logback.version}</version>
		</dependency>

		<!-- Logback Core: explicitly pinned to avoid vulnerable transitive version (CVE-2025-11226) -->
		<dependency>
			<groupId>ch.qos.logback</groupId>
			<artifactId>logback-core</artifactId>
			<version>${logback.version}</version>
		</dependency>

		<!-- SLF4J API: The Simple Logging Facade for Java (SLF4J) serves as a simple facade or abstraction for various logging frameworks -->
		<dependency>
			<groupId>org.slf4j</groupId>
			<artifactId>slf4j-api</artifactId>
			<version>${slf4j.version}</version>
		</dependency>

        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
            <version>${jackson-databind.version}</version>
        </dependency>

		<!-- TnsAI Integration: SCOPBridge for LLM support (Maven Central) -->
		<dependency>
			<groupId>io.github.tansuasici</groupId>
			<artifactId>tnsai-integration</artifactId>
			<version>0.1.1</version>
		</dependency>
	</dependencies>

	<build>
		<plugins>
			<!-- Add the Maven Compiler Plugin -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-compiler-plugin</artifactId>
				<version>3.13.0</version>
				<configuration>
					<compilerArgs>
						<arg>-parameters</arg>
					</compilerArgs>
					<source>21</source>
					<target>21</target>
				</configuration>
			</plugin>

			<!-- Define the Maven Deploy Plugin version here -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-deploy-plugin</artifactId>
				<version>3.1.3</version>
			</plugin>
		</plugins>
		<!-- The build section is used to specify build settings, including resources, plugins, and other components necessary for compiling, testing, and packaging the application. Here, it specifies the directory containing application resources like properties files, which Maven will include in the build output. -->
		<resources>
			<resource>
				<directory>src/main/resources</directory>
			</resource>
		</resources>
	</build>

</project>