sequenceDiagram
    autonumber

    participant PG as Playground
    participant DF as DirectoryFacilitator
    participant DFA as DataFetcherAgent
    participant HA1 as HotelAgent-1<br/>(Istanbul 5★ $450)
    participant HA2 as HotelAgent-2<br/>(Istanbul 5★ $400)
    participant HA3 as HotelAgent-3<br/>(Istanbul 3★ $150)
    participant CA as CustomerAgent<br/>(Istanbul 4★ max $500)

    %% ════════════════════════════════════════
    %% PHASE 1: SETUP
    %% ════════════════════════════════════════
    rect rgb(232, 245, 233)
        Note over PG,CA: PHASE 1 — SETUP (Playground.setup())

        PG->>DF: create(DirectoryFacilitator)
        PG->>DFA: create(DataFetcherAgent)

        PG->>DFA: fetchAllHotels()
        DFA-->>PG: List<Hotel> (from REST API)

        PG->>HA1: create(HotelAgent)
        PG->>HA2: create(HotelAgent)
        PG->>HA3: create(HotelAgent)

        Note over HA1,HA3: HotelAgent.setup() → adopt(HotelProviderRole) → registerWithDF()

        HA1->>HA1: @BeforeAction: beforeRegisterWithDF()<br/>validate: price>0, rooms>0, rank 1-5
        HA1->>DF: register(DFEntry)
        DF-->>HA1: true
        HA1->>HA1: @AfterAction: afterRegisterWithDF()<br/>log registration

        HA2->>DF: register(DFEntry)
        DF-->>HA2: true
        HA3->>DF: register(DFEntry)
        DF-->>HA3: true

        PG->>DFA: fetchAllCustomers()
        DFA-->>PG: List<CustomerSpec>
        PG->>CA: create(CustomerAgent)

        PG->>PG: generateTopologyCsv()<br/>regenerateNetwork()
    end

    %% ════════════════════════════════════════
    %% PHASE 2: SEARCH (CNP Initiator)
    %% ════════════════════════════════════════
    rect rgb(227, 242, 253)
        Note over CA,DF: PHASE 2 — SEARCH (CustomerRole.startSearch())

        CA->>CA: makeStep() detects IDLE state<br/>→ startSearch()
        CA->>CA: state = SEARCHING<br/>clear proposals, reset counters

        CA->>DF: queryDirectoryFacilitator()<br/>search(Istanbul, 4★, $500)
        DF-->>CA: List<DFEntry> [HA1, HA2]<br/>(HA3 excluded: rank 3 < 4)
    end

    %% ════════════════════════════════════════
    %% PHASE 3: CFP BROADCAST
    %% ════════════════════════════════════════
    rect rgb(255, 243, 224)
        Note over CA,HA2: PHASE 3 — CFP BROADCAST (broadcastCFP)

        CA->>CA: @BeforeAction: beforeBroadcastCFP()<br/>Season: WINTER → maxPrice × 0.90 = $450
        CA->>CA: state = WAITING_PROPOSALS<br/>pendingResponses = {HA1, HA2}

        par CFP to all matching hotels
            CA->>HA1: MSG_CFP(RoomQuery: Istanbul, 4★, $450)
        and
            CA->>HA2: MSG_CFP(RoomQuery: Istanbul, 4★, $450)
        end
    end

    %% ════════════════════════════════════════
    %% PHASE 4: PROPOSALS
    %% ════════════════════════════════════════
    rect rgb(243, 229, 245)
        Note over HA1,CA: PHASE 4 — PROPOSALS (HotelProviderRole)

        HA1->>HA1: handleCFPMessage()<br/>matchesQuery() → OK
        HA1->>HA1: @BeforeAction: beforeSendProposal()<br/>occupancy 20% → LOW demand<br/>multiplier 0.95 → $427.50
        HA1->>CA: MSG_PROPOSAL(RoomProposal: $427.50/night)
        HA1->>HA1: @AfterAction: afterSendProposal()<br/>log dynamic pricing

        HA2->>HA2: handleCFPMessage()<br/>matchesQuery() → OK
        HA2->>HA2: @BeforeAction: beforeSendProposal()<br/>occupancy 60% → NORMAL demand<br/>multiplier 1.075 → $430
        HA2->>CA: MSG_PROPOSAL(RoomProposal: $430/night)

        CA->>CA: handleProposalMessage(HA1)<br/>proposals.put(HA1)
        CA->>CA: @AfterAction: afterHandleProposalMessage()<br/>analytics: 1 proposal, avg=$427.50

        CA->>CA: handleProposalMessage(HA2)<br/>proposals.put(HA2)
        CA->>CA: @AfterAction: afterHandleProposalMessage()<br/>analytics: 2 proposals, avg=$428.75

        Note over CA: pendingResponses empty → checkProposalDeadline() triggers
    end

    %% ════════════════════════════════════════
    %% PHASE 5: EVALUATION
    %% ════════════════════════════════════════
    rect rgb(255, 249, 196)
        Note over CA: PHASE 5 — EVALUATE PROPOSALS

        CA->>CA: evaluateProposals()<br/>state = EVALUATING
        CA->>CA: Sort by price: HA1 ($427.50) < HA2 ($430)<br/>topCandidates = [HA1, HA2]

        alt Best price ≤ desiredPrice
            Note over CA: Direct accept (no negotiation needed)
            CA->>CA: makeReservation()
        else Best price > desiredPrice
            Note over CA: Start negotiation with first candidate
            CA->>CA: startNegotiationWithCandidate(0)
        end
    end

    %% ════════════════════════════════════════
    %% PHASE 6: NEGOTIATION
    %% ════════════════════════════════════════
    rect rgb(255, 235, 238)
        Note over CA,HA1: PHASE 6 — NEGOTIATION (Price Bargaining)

        CA->>CA: @BeforeAction: beforeStartNegotiation()<br/>marketAvg=$428.75, 2 candidates<br/>aggressiveness=0.65 → MODERATE<br/>openingOffer = $370

        CA->>HA1: MSG_NEGOTIATE_START<br/>(NegotiationOffer: $370, round 1/5)<br/>"Competing offer from HA2 at $430"

        HA1->>HA1: handleNegotiateStartMessage()<br/>effectiveMinPrice = $382.50<br/>$370 < $382.50 → counter-offer

        HA1->>CA: MSG_COUNTER_OFFER<br/>(NegotiationOffer: $420, round 1/5)

        CA->>CA: handleCounterOfferMessage()<br/>$420 > desiredPrice → counter

        CA->>CA: LinearPricingStrategy.counterOffer()<br/>desiredPrice + (maxPrice - desired) × progress<br/>= $350 + ($500 - $350) × 0.4 = $410

        CA->>HA1: MSG_COUNTER_OFFER<br/>(NegotiationOffer: $410, round 2/5)

        HA1->>HA1: handleCounterOfferMessage()<br/>$410 > effectiveMin $382.50 → ACCEPT!

        HA1->>CA: MSG_NEGOTIATE_ACCEPT<br/>(NegotiationOffer: $410, round 2)

        CA->>CA: handleNegotiateAcceptMessage()<br/>acceptNegotiation($410)
        CA->>CA: rejectRemainingCandidates()<br/>(reject HA2)
        CA->>HA2: MSG_REJECT("Another hotel selected")
    end

    %% ════════════════════════════════════════
    %% PHASE 7: RESERVATION
    %% ════════════════════════════════════════
    rect rgb(232, 245, 233)
        Note over CA,HA1: PHASE 7 — RESERVATION CONFIRMATION

        CA->>CA: state = RESERVING
        CA->>HA1: MSG_NEGOTIATE_ACCEPT<br/>(ReservationRequest: $410/night)

        HA1->>HA1: handleNegotiateAcceptMessage()<br/>reserveRoom() → OK<br/>availableRooms--

        HA1->>CA: MSG_CONFIRM<br/>(ReservationConfirmation)<br/>Confirmation #CNF-xxx<br/>$410/night (was $450, 8.9% off)

        CA->>CA: handleConfirmMessage()<br/>state = COMPLETED

        CA->>CA: @AfterAction: afterHandleConfirmMessage()<br/>AUDIT: saved $40 (8.9%)<br/>signal = BELOW_MARKET
    end

    %% ════════════════════════════════════════
    %% ALTERNATIVE: NEGOTIATION FAILURE
    %% ════════════════════════════════════════
    rect rgb(255, 224, 178)
        Note over CA,HA2: ALTERNATIVE — Negotiation Fails → Fallback

        Note over CA,HA1: If maxRounds reached and<br/>hotelOffer > maxPrice:

        CA->>CA: rejectAndTryNext()<br/>"Price too high after max rounds"
        CA->>HA1: MSG_NEGOTIATE_REJECT

        CA->>CA: startNegotiationWithCandidate(1)<br/>Move to next candidate: HA2

        CA->>HA2: MSG_NEGOTIATE_START<br/>(new negotiation with HA2)

        Note over CA: If ALL candidates exhausted:<br/>state = FAILED
    end
