sequenceDiagram
    autonumber

    actor User as 🧑 Kullanıcı<br/>(Frontend)
    participant API as Spring Boot<br/>AgentController
    participant CA as CustomerAgent<br/>CustomerRole
    participant LPS as LinearPricing<br/>Strategy
    participant HA as HotelAgent<br/>HotelProviderRole
    participant CONV as Conversation<br/>Role
    participant BRIDGE as SCOPBridge<br/>TNSAI
    participant LLM as 🤖 Ollama<br/>localhost:11434

    %% ════════════════════════════════════════
    %% NEGOTIATION FLOW
    %% ════════════════════════════════════════

    rect rgb(255, 243, 224)
        Note over CA,HA: 📋 PAZARLIK ÖNCESİ — Strateji Hazırlığı

        CA->>CA: evaluateProposals()<br/>topCandidates = [Hotel-A $430, Hotel-B $450]<br/>bestPrice $430 > desiredPrice $350

        Note right of CA: ⚡ @BeforeAction<br/>beforeStartNegotiation()

        CA->>CA: Pazar analizi:<br/>marketAvg = $440<br/>candidateCount = 2

        CA->>CA: Agresiflik hesapla:<br/>base 0.50<br/>+ 0.00 (2 aday: nötr)<br/>+ 0.15 (fiyat > ort.×1.1)<br/>= 0.65 → MODERATE

        CA->>CA: Açılış teklifi:<br/>offer = desired + (listed − desired) × (1 − agr.)<br/>= 350 + (430 − 350) × 0.35<br/>= $378
    end

    rect rgb(255, 235, 238)
        Note over CA,HA: 🤝 ROUND 1 — Açılış

        CA->>HA: MSG_NEGOTIATE_START<br/>NegotiationOffer {<br/>  offeredPrice: $378<br/>  originalPrice: $430<br/>  round: 1, maxRounds: 5<br/>  message: "Hotel-B $450 teklifi var"<br/>}

        HA->>HA: effectiveMinPrice hesapla:<br/>doluluk = 3/5 = %60<br/>scarcity = 0.60² = 0.36<br/>effMin = 382 + (450−382) × 0.36<br/>= $406.48

        Note right of HA: $378 < $406 → Reddet,<br/>karşı teklif yap

        HA->>LPS: counterOffer(base=450, min=406,<br/>flex=0.55, round=1, max=5)
        LPS-->>HA: progress = 1/5 = 0.20<br/>450 − (450−406) × 0.20 × 0.55<br/>= $445.16 → $445

        HA->>CA: MSG_COUNTER_OFFER<br/>NegotiationOffer {<br/>  offeredPrice: $445<br/>  round: 1<br/>  message: "$445/gece teklif ediyoruz"<br/>}
    end

    rect rgb(232, 245, 233)
        Note over CA,HA: 🤝 ROUND 2 — Karşılıklı Pazarlık

        CA->>CA: $445 > desiredPrice $350 → devam
        CA->>CA: round = 2, maxRounds = 5

        CA->>LPS: counterOffer(desired=350,<br/>max=500, round=2, max=5)
        LPS-->>CA: progress = 2/5 = 0.40<br/>350 + (500−350) × 0.40<br/>= $410

        Note right of CA: $410 < $445 → Gönder<br/>(kaldıraç: Hotel-B $450)

        CA->>HA: MSG_COUNTER_OFFER<br/>NegotiationOffer {<br/>  offeredPrice: $410<br/>  round: 2<br/>  message: "$410 nasıl? Rakip $450 teklif var"<br/>}

        HA->>HA: $410 ≥ effMin $406 → KABUL! ✅

        HA->>CA: MSG_NEGOTIATE_ACCEPT<br/>NegotiationOffer {<br/>  offeredPrice: $410<br/>  round: 2<br/>  message: "Anlaştık! $410/gece"<br/>}
    end

    rect rgb(227, 242, 253)
        Note over CA,HA: 📝 REZERVASYON ONAYI

        CA->>CA: acceptNegotiation($410)<br/>rejectRemainingCandidates()<br/>state = RESERVING

        CA->>HA: MSG_NEGOTIATE_ACCEPT<br/>ReservationRequest {<br/>  negotiatedPrice: $410<br/>  numberOfNights: 1<br/>}

        HA->>HA: reserveRoom()<br/>synchronized: 2/5 → 1/5 oda kaldı

        HA->>CA: MSG_CONFIRM<br/>ReservationConfirmation {<br/>  confirmNo: "CNF-a7b3..."<br/>  price: $410, original: $450<br/>  discount: %8.9<br/>}

        CA->>CA: state = COMPLETED ✅

        Note right of CA: ⚡ @AfterAction<br/>afterHandleConfirmMessage()

        CA->>CA: AUDIT:<br/>Tasarruf: $40 (%8.9)<br/>Pazar sinyali: BELOW_MARKET<br/>(final $410 < ort. $440 × 0.95)
    end

    rect rgb(243, 229, 245)
        Note over User,LLM: 🤖 LLM ENTEGRASYONU — Conversation.chat() ile Agent'a Soru Sorma

        User->>API: POST /api/agents/Customer-1/chat<br/>{ message: "Rezervasyonun nasıl gitti?" }

        API->>API: findAgent("Customer-1")<br/>agent.as(Conversation.class)

        API->>CONV: chat("Rezervasyonun nasıl gitti?")

        CONV->>CONV: initializeLLM()<br/>if (!llmInitialized)

        CONV->>BRIDGE: resolveLLMSpec(agent, playground)

        BRIDGE-->>CONV: LLMConfiguration {<br/>  provider: "OLLAMA"<br/>  model: "glm-4.7:cloud"<br/>  apiUrl: "http://localhost:11434"<br/>}

        CONV->>CONV: buildSystemPrompt()

        Note over CONV: System Prompt İçeriği:<br/>─────────────────────<br/>@AgentSpec.description<br/>@RoleSpec.responsibilities [4]<br/>@RoleSpec.communication (FRIENDLY, tr/en)<br/>@State alanları (location, state,<br/>  proposals, negotiationRound...)<br/>@Action listesi → tools[]

        CONV->>CONV: buildToolsArray()<br/>@Action metotlarını JSON tool'a çevir

        CONV->>LLM: POST /api/chat<br/>{<br/>  model: "glm-4.7:cloud",<br/>  messages: [<br/>    { role: "system", content: systemPrompt },<br/>    { role: "user", content: "Rezervasyonun nasıl gitti?" }<br/>  ],<br/>  tools: [<br/>    { name: "startSearch", params: {...} },<br/>    { name: "evaluateProposals", params: {...} },<br/>    ...<br/>  ],<br/>  temperature: 0.7<br/>}

        LLM-->>CONV: {<br/>  role: "assistant",<br/>  content: "Rezervasyonum başarıyla<br/>  tamamlandı! Hotel-A'da $410/gece<br/>  fiyatla anlaştım. Orijinal fiyat<br/>  $450 idi, %8.9 indirim aldım."<br/>}

        CONV-->>API: "Rezervasyonum başarıyla..."
        API-->>User: { response: "Rezervasyonum başarıyla..." }
    end

    rect rgb(255, 249, 196)
        Note over User,LLM: 🤖 LLM TOOL CALL — Agent'a Aksiyon Yaptırma

        User->>API: POST /api/agents/Customer-2/chat<br/>{ message: "Otel ara bana" }

        API->>CONV: chat("Otel ara bana")

        CONV->>LLM: POST /api/chat<br/>{ messages: [...], tools: [...] }

        LLM-->>CONV: {<br/>  role: "assistant",<br/>  tool_calls: [{<br/>    name: "startSearch",<br/>    arguments: {}<br/>  }]<br/>}

        Note over CONV: tool_call algılandı!

        CONV->>CONV: executeToolCall()<br/>→ CustomerRole.startSearch()

        Note over CONV: Arama başlatıldı,<br/>CNP protokolü tetiklendi

        CONV->>LLM: POST /api/chat<br/>{ messages: [...,<br/>  tool_result: "Search started<br/>  for 4★ in Istanbul"<br/>] }

        LLM-->>CONV: {<br/>  content: "Sizin için Istanbul'da<br/>  4 yıldızlı otel araması başlattım!<br/>  Sonuçları bekleyelim."<br/>}

        CONV-->>API: "Sizin için Istanbul'da..."
        API-->>User: { response: "Sizin için Istanbul'da..." }
    end
