classDiagram
    direction TB

    %% ════════════════════════════════════════
    %% SCOP FRAMEWORK BASE CLASSES
    %% ════════════════════════════════════════
    class Playground {
        <<SCOP Framework>>
        +setup()*
        +create(Agent) Agent
        +findAgent(name) Agent
        +getAgent(Class, name) T
        +getScenarioAgents() List
        +getTick() Tick
    }

    class Agent {
        <<SCOP Framework>>
        #setup()*
        +getName() String
        +adopt(Role)
        +as(Class~T~) T
        +getPlayground() Playground
        +getLogger() Logger
    }

    class Role {
        <<SCOP Framework>>
        #getOwner() Agent
        #getAgent(Class, name) T
        #sendMessage(type, payload, receiver)
        +getIdentifier() Identifier
    }

    class Environment {
        <<SCOP Framework>>
        #setup()*
        +getName() String
    }

    class NetworkEnvironment {
        <<SCOP Framework>>
        +generateNetwork(path, from, to, sep)
        +getNeighbors(agent) List
        +getNetworkMetrics() NetworkMetrics
        +add(Agent)
    }

    class Conversation {
        <<SCOP Framework>>
        +chat(message) String
    }

    class Message~T~ {
        <<SCOP Framework>>
        +getPayload() T
        +getSender() Identifier
        +getType() String
    }

    %% ════════════════════════════════════════
    %% AGENTS
    %% ════════════════════════════════════════
    class HotelReservationPlayground {
        -directoryFacilitator: DirectoryFacilitator
        -hotelEnv: NetworkEnvironment
        -dataFetcherAgent: DataFetcherAgent
        -hotelAgents: List~HotelAgent~
        -customerAgents: List~CustomerAgent~
        +setup()
        -createHotelAgents()
        -createCustomerAgents()
        -regenerateNetwork()
        -generateTopologyCsv() Path
        +triggerAllSearches()
        +triggerSearch(customerName)
    }

    class HotelAgent {
        -hotelId: String
        -hotelName: String
        -location: String
        -rank: int
        -basePrice: double
        -totalRooms: int
        -availableRooms: int
        #setup()
        +reserveRoom() boolean
        +getDisplayName() String
    }

    class CustomerAgent {
        -desiredLocation: String
        -desiredRank: int
        -maxPrice: double
        -desiredPrice: double
        #setup()
        +startSearch()
    }

    class DataFetcherAgent {
        -apiPort: int
        #setup()
    }

    %% ════════════════════════════════════════
    %% ROLES
    %% ════════════════════════════════════════
    class CustomerRole {
        -desiredLocation: String
        -desiredRank: int
        -maxPrice: double
        -desiredPrice: double
        -state: CustomerState
        -proposals: Map~String,RoomProposal~
        -pendingResponses: Set~String~
        -topCandidates: List~RoomProposal~
        -pricingStrategy: BuyerPricingStrategy
        -totalProposalCount: int
        -proposalPriceSum: double
        +startSearch()
        -queryDirectoryFacilitator()
        -broadcastCFP(hotels)
        +handleProposalMessage(Message)
        +handleRefuseMessage(Message)
        +evaluateProposals()
        -startNegotiationWithCandidate(index)
        +handleCounterOfferMessage(Message)
        +handleNegotiateAcceptMessage(Message)
        +handleNegotiateRejectMessage(Message)
        -makeReservation()
        +handleConfirmMessage(Message)
        -beforeBroadcastCFP(params) ActionParams
        -afterHandleProposalMessage(params)
        -beforeStartNegotiation(params) ActionParams
        -afterHandleConfirmMessage(params)
    }

    class HotelProviderRole {
        -hotelId: String
        -hotelName: String
        -location: String
        -rank: int
        -basePrice: double
        -baseMinPrice: double
        -negotiationFlexibility: double
        -pricingStrategy: SellerPricingStrategy
        +handleCFPMessage(Message)
        -sendProposal(customer)
        -sendRefusal(customer, reason)
        +handleAcceptMessage(Message)
        +handleRejectMessage(Message)
        +handleNegotiateStartMessage(Message)
        +handleCounterOfferMessage(Message)
        +handleNegotiateAcceptMessage(Message)
        +registerWithDF()
        -getEffectiveMinPrice() double
        -beforeSendProposal(params) ActionParams
        -afterSendProposal(params)
        -beforeRegisterWithDF(params) ActionParams
        -afterRegisterWithDF(params)
    }

    class DataFetcherRole {
        -baseUrl: String
        -httpClient: HttpClient
        -objectMapper: ObjectMapper
        +fetchAllHotels() List~Hotel~
        +fetchHotelById(id) Hotel
        +searchHotels(city, rank, price) List~Hotel~
        +fetchAllCustomers() List~CustomerSpec~
        +fetchCustomerById(id) CustomerSpec
    }

    %% ════════════════════════════════════════
    %% ENVIRONMENTS
    %% ════════════════════════════════════════
    class DirectoryFacilitator {
        -registry: ConcurrentHashMap~String,DFEntry~
        +register(entry) boolean
        +deregister(agentId) boolean
        +search(location, rank, price) List~DFEntry~
        +getAllEntries() List~DFEntry~
        +getRegisteredCount() int
    }

    %% ════════════════════════════════════════
    %% STRATEGY PATTERN
    %% ════════════════════════════════════════
    class BuyerPricingStrategy {
        <<interface>>
        +counterOffer(desired, max, round, maxRounds) double
    }

    class SellerPricingStrategy {
        <<interface>>
        +counterOffer(base, min, flex, round, maxRounds) double
    }

    class LinearPricingStrategy {
        +counterOffer(desired, max, round, maxRounds) double
        +counterOffer(base, min, flex, round, maxRounds) double
    }

    %% ════════════════════════════════════════
    %% MESSAGE PAYLOADS
    %% ════════════════════════════════════════
    class RoomQuery {
        -customerId: String
        -location: String
        -minRank: int
        -maxPrice: double
    }

    class RoomProposal {
        -proposalId: String
        -hotelId: String
        -hotelName: String
        -location: String
        -rank: int
        -pricePerNight: double
        -timestamp: long
        -negotiatedPrice: double
    }

    class NegotiationOffer {
        -proposalId: String
        -hotelId: String
        -offeredPrice: double
        -originalPrice: double
        -round: int
        -maxRounds: int
        -message: String
    }

    class ReservationRequest {
        -requestId: String
        -customerId: String
        -hotelId: String
        -negotiatedPrice: double
        -numberOfNights: int
    }

    class ReservationConfirmation {
        -confirmationNumber: String
        -customerId: String
        -hotelId: String
        -hotelName: String
        -pricePerNight: double
        -totalPrice: double
        -originalPrice: double
        -discountPercent: double
    }

    %% ════════════════════════════════════════
    %% SUPPORT CLASSES
    %% ════════════════════════════════════════
    class DFEntry {
        -agentId: String
        -agentName: String
        -hotelId: String
        -hotelName: String
        -location: String
        -rank: int
        -basePrice: double
        -available: boolean
        +matches(location, rank, price) boolean
    }

    class ActivityLog {
        <<utility>>
        -entries: List~Entry~$
        +log(from, to, type, detail)$
        +getEntriesSince(timestamp) List$
        +clear()$
    }

    class CustomerState {
        <<enumeration>>
        IDLE
        SEARCHING
        WAITING_PROPOSALS
        EVALUATING
        NEGOTIATING
        RESERVING
        COMPLETED
        FAILED
    }

    class ActionParams {
        <<TNSAI>>
        -params: Map~String,Object~
        -actionName: String
        +set(key, value)
        +getString(key) String
        +getDouble(key) double
        +getInt(key) int
        +getBoolean(key) boolean
        +has(key) boolean
    }

    %% ════════════════════════════════════════
    %% INHERITANCE
    %% ════════════════════════════════════════
    Playground <|-- HotelReservationPlayground
    Agent <|-- HotelAgent
    Agent <|-- CustomerAgent
    Agent <|-- DataFetcherAgent
    Role <|-- CustomerRole
    Role <|-- HotelProviderRole
    Role <|-- DataFetcherRole
    Role <|-- Conversation
    Environment <|-- DirectoryFacilitator
    Environment <|-- NetworkEnvironment
    BuyerPricingStrategy <|.. LinearPricingStrategy
    SellerPricingStrategy <|.. LinearPricingStrategy

    %% ════════════════════════════════════════
    %% COMPOSITIONS & ASSOCIATIONS
    %% ════════════════════════════════════════
    HotelReservationPlayground *-- "1" DirectoryFacilitator : creates
    HotelReservationPlayground *-- "1" NetworkEnvironment : creates
    HotelReservationPlayground *-- "1" DataFetcherAgent : creates
    HotelReservationPlayground *-- "0..*" HotelAgent : creates
    HotelReservationPlayground *-- "0..*" CustomerAgent : creates

    HotelAgent ..> HotelProviderRole : adopts
    HotelAgent ..> Conversation : adopts
    CustomerAgent ..> CustomerRole : adopts
    CustomerAgent ..> Conversation : adopts
    DataFetcherAgent ..> DataFetcherRole : adopts

    CustomerRole --> BuyerPricingStrategy : uses
    HotelProviderRole --> SellerPricingStrategy : uses

    CustomerRole ..> DirectoryFacilitator : queries
    HotelProviderRole ..> DirectoryFacilitator : registers

    CustomerRole ..> RoomQuery : creates
    CustomerRole ..> ReservationRequest : creates
    CustomerRole ..> NegotiationOffer : creates/receives
    CustomerRole --> CustomerState : tracks

    HotelProviderRole ..> RoomProposal : creates
    HotelProviderRole ..> ReservationConfirmation : creates
    HotelProviderRole ..> NegotiationOffer : creates/receives

    DirectoryFacilitator *-- "0..*" DFEntry : stores

    CustomerRole ..> ActionParams : hook data
    HotelProviderRole ..> ActionParams : hook data

    CustomerRole ..> ActivityLog : logs
    HotelProviderRole ..> ActivityLog : logs
